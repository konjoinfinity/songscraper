# ── songscraper environment ──────────────────────────────────────────────────
# Copy to `.env` for local dev. NEVER commit a real `.env`. In production these
# come from Cloud Run env vars / Secret Manager — see DEPLOY.md.

# HTTP
PORT=8080
# Shared secret required in the `x-api-key` header on POST /scrape
API_KEY=change-me-to-a-long-random-string

# Google OAuth (from the Google Cloud console — OAuth 2.0 Client, type "Web application")
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Must exactly match an Authorized redirect URI on the OAuth client.
# Local dev: http://localhost:8080/oauth2callback
# Prod: https://<your-cloud-run-url>/oauth2callback
OAUTH_REDIRECT_URI=http://localhost:8080/oauth2callback

# Long-lived refresh token minted by the one-time /auth -> /oauth2callback flow.
# Leave blank until you have run the bootstrap; then store it as a secret.
REFRESH_TOKEN=

# Google Docs template to copy for each new song (a 2-column-table doc with the
# "Song Title - Artist Name" and "col2" placeholders).
TEMPLATE_DOC_ID=1xM26IwbTj7L9VNXwDLyXV4ZWSdLUvRybDclq_u46My4
# Optional: Drive folder to create new docs in. Blank = My Drive root.
DRIVE_FOLDER_ID=

# Puppeteer: in the container we use the bundled Chromium. To point at a system
# Chrome instead, set this to its absolute path.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
